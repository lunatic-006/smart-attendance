# Face Recognition Pipeline Configuration
# Copy this file to .env and customize

# ============================================
# PIPELINE SELECTION
# ============================================
# Options: "standard" or "advanced"
# - standard: MTCNN + FaceNet (default, recommended for CPU)
# - advanced: YOLOv8 + ArcFace (more accurate, slower on CPU)
FACE_PIPELINE=standard

# ============================================
# STANDARD PIPELINE OPTIONS
# ============================================
# Tolerance for face matching (lower = stricter)
# Range: 0.0 - 1.0
# Recommended: 0.5 (default), 0.4 (stricter), 0.6 (more lenient)
STANDARD_TOLERANCE=0.5

# ============================================
# ADVANCED PIPELINE OPTIONS
# ============================================
# YOLOv8 model size (larger = more accurate but slower)
# Options: yolov8n-face (nano, fastest), yolov8s-face, yolov8m-face, yolov8l-face, yolov8x-face
# Recommended: yolov8n-face for CPU-only systems
YOLO_MODEL=yolov8n-face

# Confidence threshold for advanced pipeline (cosine similarity)
# Range: 0.0 - 1.0
# Recommended: 0.5 (default), 0.55 (stricter), 0.45 (more lenient)
ADVANCED_CONFIDENCE=0.5

# ============================================
# GENERAL OPTIONS
# ============================================
# Force CPU usage even if GPU is available
# Options: "true" or "false"
# Recommended: "true" for Intel i7 without GPU
FORCE_CPU=true

# Enable liveness detection (prevents photo/video spoofing)
# Options: "true" or "false"
ENABLE_LIVENESS=true

# Liveness detection method
# Options: "basic" (fast, simple) or "advanced" (thorough, uses facial landmarks)
# Recommended: "advanced" for better security
LIVENESS_TYPE=advanced

# ============================================
# DATABASE OPTIONS (if using alternative)
# ============================================
# DATABASE_URL=sqlite:///./database/smart_attendance.db

# ============================================
# API OPTIONS
# ============================================
# API port
API_PORT=8000

# Debug mode
DEBUG=false
